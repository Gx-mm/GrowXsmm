    { "src": "^/privacy\\.html$", "status": 301, "headers": { "Location": "/privacy" } },
    { "src": "^/terms\\.html$", "status": 301, "headers": { "Location": "/terms" } },
    { "src": "^/wallet\\.html$", "status": 301, "headers": { "Location": "/wallet" } },

    { "src": "^/gpay\\.html$", "status": 301, "headers": { "Location": "/gpay" } },
    { "src": "^/phonepe\\.html$", "status": 301, "headers": { "Location": "/phonepe" } },
    { "src": "^/airtel\\.html$", "status": 301, "headers": { "Location": "/airtel" } },
    { "src": "^/fampay\\.html$", "status": 301, "headers": { "Location": "/fampay" } },

    { "src": "^/n2\\.html$", "status": 301, "headers": { "Location": "/n2" } },
    { "src": "^/o\\.html$", "status": 301, "headers": { "Location": "/o" } },
    { "src": "^/error\\.html$", "status": 301, "headers": { "Location": "/error" } },

    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/error.html" }

