<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GrowX Premium Dashboard</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box;font-family:'Poppins',sans-serif;}

body{
background: radial-gradient(circle at top,#0b1d3a,#020814);
color:white;
padding:20px;
overflow-x:hidden;
}

/* particles */
.particle{
position:fixed;
width:3px;
height:3px;
background:white;
border-radius:50%;
opacity:0.4;
animation:float 8s linear infinite;
}

@keyframes float{
0%{transform:translateY(100vh)}
100%{transform:translateY(-10vh)}
}

.header{
display:flex;
justify-content:space-between;
align-items:center;
margin-bottom:30px;
}

.logo{
font-size:26px;
font-weight:600;
}

.icons{
display:flex;
gap:15px;
}

.card{
background:rgba(255,255,255,0.05);
backdrop-filter:blur(15px);
border-radius:18px;
padding:25px;
border:1px solid rgba(255,255,255,0.08);
box-shadow:
0 0 10px rgba(0,150,255,0.3),
0 0 20px rgba(0,150,255,0.3);
}

.top{
display:grid;
grid-template-columns:1fr 1fr;
gap:20px;
margin-bottom:25px;
}

.balance{
font-size:36px;
margin-top:10px;
font-weight:600;
}

.actions{
display:flex;
gap:15px;
flex-wrap:wrap;
align-items:center;
}

/* 🔥 PREMIUM BUTTON */
.btn{
padding:14px 24px;
border-radius:50px;
border:none;
color:#fff;
font-size:16px;
font-weight:500;
cursor:pointer;
display:flex;
align-items:center;
gap:10px;
transition:all 0.3s ease;
position:relative;
overflow:hidden;
}

.btn::before{
content:"";
position:absolute;
top:0;
left:-100%;
width:100%;
height:100%;
background:linear-gradient(120deg,transparent,rgba(255,255,255,0.4),transparent);
transition:0.5s;
}

.btn:hover::before{
left:100%;
}

.btn:hover{
transform:translateY(-4px) scale(1.05);
}

.btn:active{
transform:scale(0.95);
}

/* Colors */
.actions .btn:nth-child(1){
background:linear-gradient(145deg,#ffd54f,#ffb300);
box-shadow:0 0 10px rgba(255,193,7,0.8),0 0 25px rgba(255,193,7,0.6);
}

.actions .btn:nth-child(2){
background:linear-gradient(145deg,#00ff87,#00c853);
box-shadow:0 0 10px rgba(0,255,135,0.8),0 0 25px rgba(0,255,135,0.6);
}

.actions .btn:nth-child(3){
background:linear-gradient(145deg,#42a5f5,#1e88e5);
box-shadow:0 0 10px rgba(33,150,243,0.8),0 0 25px rgba(33,150,243,0.6);
}

.stats{
display:grid;
grid-template-columns:1fr 1fr;
gap:20px;
margin-bottom:30px;
}

.title{
font-size:22px;
margin-bottom:20px;
}

.services{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
}

.service{text-align:center;}

.icon img{width:40px;margin-bottom:10px;}

.buy{
margin-top:12px;
padding:10px 18px;
border:none;
border-radius:30px;
cursor:pointer;
background:linear-gradient(45deg,#ffcc33,#ff6600);
box-shadow:0 0 15px rgba(255,170,0,0.9);
}

.footer{
text-align:center;
margin-top:40px;
opacity:0.6;
font-size:13px;
}

@media(max-width:700px){
.top{grid-template-columns:1fr;}
.stats{grid-template-columns:1fr;}
}
</style>

<script>
if(!localStorage.getItem("userID")){
  window.location.href = "index.html";
}
</script>

</head>

<body>

<div class="header">
<div class="logo">Grow<span style="color:#f1c40f;"><strong>X</strong></span></div>
<div class="icons">
<div onclick="location.href='n2.html'" style="cursor:pointer;font-size:22px;">🔔</div>
<div onclick="location.href='setting.html'" style="cursor:pointer;font-size:22px;">⚙</div>
</div>
</div>

<div class="top">

<div class="card">
<h2 id="welcome">Welcome 👋</h2>
<p>User ID: <span id="userid"></span> <span style="color:#00ff9c;">✔ Verified</span></p>
<p style="opacity:0.7;margin-top:15px;">Available Balance</p>
<div class="balance" id="balance">₹0</div>
</div>

<div class="actions">
<button class="btn" onclick="location.href='wallet.html'">💳 Wallet</button>
<button class="btn" onclick="location.href='o.html'">🛒 New Order</button>
<button class="btn" onclick="location.href='history.html'">🕘 History</button>
</div>

</div>

<div class="stats">
<div class="card">
<h2>9999+</h2>
<p>Total Orders</p>
</div>
<div class="card">
<h2>9999+</h2>
<p>Completed Orders</p>
</div>
</div>

<!-- ✅ SERVICES BACK -->
<div class="title">Our Popular Services</div>

<div class="services">
<div class="card service">
<div class="icon"><img src="https://upload.wikimedia.org/wikipedia/commons/a/a5/Instagram_icon.png"></div>
<h3>Instagram</h3>
<p>100K Reel Views - ₹8 ONLY</p>
<button class="buy" onclick="location.href='o.html'">Buy Now</button>
</div>

<div class="card service">
<div class="icon"><img src="https://upload.wikimedia.org/wikipedia/commons/a/a5/Instagram_icon.png"></div>
<h3>Instagram</h3>
<p>10K Followers - ₹60 ONLY</p>
<button class="buy" onclick="location.href='o.html'">Buy Now</button>
</div>

<div class="card service">
<div class="icon"><img src="https://upload.wikimedia.org/wikipedia/commons/a/a5/Instagram_icon.png"></div>
<h3>Instagram</h3>
<p>100K Post/Reel Likes - ₹100 ONLY</p>
<button class="buy" onclick="location.href='o.html'">Buy Now</button>
</div>

<div class="card service">
<div class="icon"><img src="https://upload.wikimedia.org/wikipedia/commons/a/a5/Instagram_icon.png"></div>
<h3>Instagram</h3>
<p>100K Story Views - ₹150 ONLY</p>
<button class="buy" onclick="location.href='o.html'">Buy Now</button>
</div>
</div>

<div class="footer">© 2026 GrowX • All Rights Reserved</div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<script>

const supabaseClient = window.supabase.createClient(
"https://sgabwjdydpdhjhzgncmq.supabase.co",
"sb_publishable_uGNWbH6gSVTBbTRotRGXQQ_a7n_mtzb"
);

const userID = localStorage.getItem("userID");

async function loadUser(){
let { data } = await supabaseClient
.from("USER")
.select("*")
.eq("USERID", userID)
.single();

if(data){
document.getElementById("welcome").innerText = "Welcome " + data.USERNAME + " 👋";
document.getElementById("userid").innerText = data.USERID;
document.getElementById("balance").innerText = "₹" + parseFloat(data.BALANCE).toFixed(3);
}
}

loadUser();

for(let i=0;i<40;i++){
let p=document.createElement("div");
p.className="particle";
p.style.left=Math.random()*100+"vw";
p.style.animationDuration=(5+Math.random()*6)+"s";
document.body.appendChild(p);
}

</script>

</body>
</html>
